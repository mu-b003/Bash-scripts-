#!/bin/bash

echo "====== Privilege Escalation Check ======"

# من أنا
echo "[+] Current User:"
whoami

# sudo permissions
echo "[+] SUDO Permissions:"
sudo -l

# ملفات SUID
echo "[+] SUID Files:"
find / -perm -4000 -type f 2>/dev/null

# صلاحيات ملفات حساسة
echo "[+] /etc/passwd Permissions:"
ls -l /etc/passwd

# العمليات الجارية
echo "[+] Running Processes:"
ps aux | head -n 10

echo "================================"
